---
import config from "@/config/config.json" with { type: "json" };
const { theme_switcher }: { theme_switcher: boolean } = config.settings;
const { className }: { className?: string } = Astro.props;
---

{theme_switcher && (
  <div class={`theme-switcher ${className || ""}`}>
    <input id="theme-switcher-input" data-theme-switcher type="checkbox" class="hidden" />
    <label for="theme-switcher-input" class="cursor-pointer flex items-center justify-center p-2">
      <span class="sr-only">Toggle theme</span>
      <span class="dark:hidden">☀️</span>
      <span class="hidden dark:inline">🌙</span>
    </label>
  </div>
)}

<style>
  .hidden { display: none; }
</style>

<script>
  const switcher = document.getElementById('theme-switcher-input') as HTMLInputElement | null;

  function applyTheme() {
    const savedTheme = localStorage.getItem("starlight-theme") || "dark";
    document.documentElement.dataset.theme = savedTheme;
    if (switcher) switcher.checked = savedTheme === "dark";
  }

  if (switcher) {
    switcher.addEventListener("change", () => {
      const newTheme = switcher.checked ? "dark" : "light";
      document.documentElement.dataset.theme = newTheme;
      localStorage.setItem("starlight-theme", newTheme);
    });
  }

  applyTheme();
  document.addEventListener("astro:after-swap", applyTheme);
</script>