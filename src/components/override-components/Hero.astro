---
// Video will be loaded from public folder
---

<section class="hero-section bg-[#0d0d0d] py-20 px-4">
  <div class="max-w-6xl mx-auto text-center">
    <h1 class="text-5xl font-bold text-white mb-6">
      The <span class="text-[#00ff41]">BooMBox</span> Card Vault
    </h1>
    <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
      AI Forensics & Digital Grading. Professional-grade analysis for high-value collectibles.
    </p>

    {Astro.url.pathname === '/' && (
      <div class="relative group video-container border-2 border-[#00ff41] rounded-xl overflow-hidden aspect-video flex items-center justify-center shadow-[0_0_20px_rgba(0,255,65,0.2)]" style="background: rgba(5, 5, 5, 0.2); backdrop-filter: blur(10px);">
        <video 
          id="hero-video"
          src="/assets/boom-intro.mp4" 
          width="100%" 
          height="auto" 
          autoplay 
          muted 
          loop 
          playsinline
          class="w-full h-full object-cover"
          style="background: transparent;"
        >
          Your browser does not support the video tag.
        </video>

        <div class="absolute bottom-4 right-4 flex items-center gap-3 bg-black/60 backdrop-blur-md p-3 rounded-lg border border-[#00ff41]/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <button id="mute-btn" class="text-[#00ff41] hover:scale-110 transition-transform">
            <span id="mute-icon">🔇</span>
          </button>
          <input 
            type="range" 
            id="volume-slider" 
            min="0" 
            max="1" 
            step="0.1" 
            value="0"
            class="w-24 accent-[#00ff41] cursor-pointer"
          />
        </div>
      </div>
    )}
  </div>
</section>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  const muteBtn = document.getElementById('mute-btn');
  const muteIcon = document.getElementById('mute-icon');
  const volumeSlider = document.getElementById('volume-slider') as HTMLInputElement;

  if (video && muteBtn && volumeSlider && muteIcon) {
    // Handle Mute Toggle
    muteBtn.addEventListener('click', () => {
      video.muted = !video.muted;
      muteIcon.textContent = video.muted ? '🔇' : '🔊';
      volumeSlider.value = video.muted ? "0" : video.volume.toString();
    });

    // Handle Volume Slide
    volumeSlider.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      video.volume = parseFloat(val);
      video.muted = video.volume === 0;
      muteIcon.textContent = video.muted ? '🔇' : '🔊';
    });
  }
</script>