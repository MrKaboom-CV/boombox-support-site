---
// 1. Import your video file from the assets folder
import boomIntroVideo from "../../assets/boom-intro.mp4";
---

<section class="hero-section bg-[#0d0d0d] py-20 px-4">
  <div class="max-w-6xl mx-auto text-center">
    <h1 class="text-5xl font-bold text-white mb-6">
      The <span class="text-[#00ff41]">BooMBox</span> Card Vault
    </h1>
    <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
      AI Forensics & Digital Grading. Professional-grade analysis for high-value collectibles.
    </p>

    <div class="video-container border-2 border-[#00ff41] rounded-xl overflow-hidden bg-black aspect-video flex items-center justify-center shadow-[0_0_20px_rgba(0,255,65,0.2)]">
      
      <video 
        src={boomIntroVideo} 
        width="100%" 
        height="auto" 
        autoplay 
        muted 
        loop 
        playsinline
        class="w-full h-full object-cover"
      >
        Your browser does not support the video tag.
      </video>

    </div>
  </div>
</section>