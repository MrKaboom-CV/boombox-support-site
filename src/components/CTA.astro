---
import { getEntry } from "astro:content";
import Button from "./user-components/Button.astro";
import Section from "./Section.astro";

const locale = Astro.currentLocale || "en";

// Fixed the syntax error in the string interpolation
const entryId = locale === "en" ? "call-to-action" : `${locale}/call-to-action`;
const cta = await getEntry("ctaSection", entryId);

const { title, description, enable, fill_button, outline_button } = cta?.data ?? {};

// Set a safe fallback path (Home) instead of the obsolete overview page
const safeFallback = "/";
---

{
  enable && (
    <div class="cta-wrapper">
      <Section title={title} description={description}>
        <div class="cta-buttons">
          {fill_button?.enable && (
            <Button
              label={fill_button.label || "Get Started"}
              link={fill_button.link || safeFallback}
              variant="primary"
            />
          )}
          {outline_button?.enable && (
            <Button
              label={outline_button.label || "View Docs"}
              link={outline_button.link || safeFallback}
              variant="outline-primary"
            />
          )}
        </div>
      </Section>
    </div>
  )
}

<style>
  /* Container Layout */
  .cta-wrapper {
    padding: 2rem 1rem;
    width: 100%;
  }

  /* Centering the buttons via CSS (Replaces the old <script> logic) */
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  /* Light mode styling */
  :global([data-theme="light"]) .cta-wrapper {
    background-color: #f9fafb;
    background-blend-mode: multiply;
  }

  /* Dark mode styling */
  :global([data-theme="dark"]) .cta-wrapper {
    /* Ensure cta-bg.png is in your /public folder for this path to work */
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url("/cta-bg.png") no-repeat center;
    background-size: cover;
    position: relative;
    border-radius: 0.5rem;
  }
</style>