---
import { getEntry } from "astro:content";
import Button from "./user-components/Button.astro";
import Section from "./Section.astro";

const cta = await getEntry("ctaSection", "call-to-action");
const { title, description, enable, fill_button, outline_button } = cta?.data ?? {};
---

{enable && (
  <div class="cta-wrapper py-20">
    <Section title={title} description={description}>
      <div class="flex justify-center gap-4 mt-8">
        {fill_button?.enable && (
          <Button label={fill_button.label} link="/configurations" variant="primary" />
        )}
        {outline_button?.enable && (
          <Button label={outline_button.label} link="/support" variant="outline-primary" />
        )}
      </div>
    </Section>
  </div>
)}

<style>
  :global([data-theme="dark"]) .cta-wrapper {
    background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url("/cta-bg.png") no-repeat center;
    background-size: cover;
  }
</style>